{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/admin",
      "destination": "/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/admin/:slug",
      "destination": "/admin-space?space=:slug"
    },
    {
      "source": "/:slug",
      "destination": "/play?space=:slug"
    }
  ]
}
