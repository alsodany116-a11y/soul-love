{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/admin",
      "destination": "/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/admin/:slug",
      "destination": "/admin-space.html?space=:slug"
    },
    {
      "source": "/:slug",
      "destination": "/play.html?space=:slug"
    }
  ]
}
